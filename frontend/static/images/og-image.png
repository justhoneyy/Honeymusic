<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0a0a0a"/>
      <stop offset="100%" style="stop-color:#1a1a1a"/>
    </linearGradient>
    <linearGradient id="accent" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1ED760"/>
      <stop offset="100%" style="stop-color:#1a9e4a"/>
    </linearGradient>
  </defs>
  <rect width="1200" height="630" fill="url(#bg)"/>
  <circle cx="600" cy="315" r="200" fill="url(#accent)" opacity="0.1"/>
  <circle cx="600" cy="315" r="150" fill="url(#accent)" opacity="0.15"/>
  <text x="600" y="280" text-anchor="middle" font-family="Arial, sans-serif" font-size="120" font-weight="800" fill="#1ED760">🍯</text>
  <text x="600" y="380" text-anchor="middle" font-family="Arial, sans-serif" font-size="64" font-weight="800" fill="white">Honey Music</text>
  <text x="600" y="430" text-anchor="middle" font-family="Arial, sans-serif" font-size="24" fill="#b3b3b3">Premium Music Streaming Experience</text>
</svg>
